{
	"name": "@marstv/tvos",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"reset-project": "node ./scripts/reset-project.js",
		"lint": "expo lint",
		"prebuild": "expo prebuild --clean",
		"prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
		"deploy": "npx expo export -p web && npx eas-cli@latest deploy"
	},
	"dependencies": {
		"@expo/vector-icons": "catalog:",
		"@marstv/api": "workspace:*",
		"@marstv/core": "workspace:*",
		"@marstv/ui": "workspace:*",
		"@react-navigation/bottom-tabs": "catalog:",
		"@react-navigation/elements": "catalog:",
		"@react-navigation/native": "catalog:",
		"expo": "catalog:react-native-tvos",
		"expo-build-properties": "catalog:",
		"expo-constants": "catalog:react-native-tvos",
		"expo-dev-client": "catalog:",
		"expo-font": "catalog:",
		"expo-glass-effect": "catalog:",
		"expo-image": "catalog:",
		"expo-linear-gradient": "catalog:",
		"expo-linking": "catalog:react-native-tvos",
		"expo-router": "catalog:react-native-tvos",
		"expo-splash-screen": "catalog:",
		"expo-status-bar": "catalog:",
		"expo-symbols": "catalog:",
		"expo-system-ui": "catalog:",
		"expo-web-browser": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-native": "catalog:react-native-tvos",
		"react-native-gesture-handler": "catalog:",
		"react-native-reanimated": "catalog:react-native-tvos",
		"react-native-safe-area-context": "catalog:",
		"react-native-screens": "catalog:",
		"react-native-web": "catalog:",
		"react-native-worklets": "catalog:react-native-tvos"
	},
	"devDependencies": {
		"@react-native-tvos/config-tv": "catalog:",
		"@types/react": "catalog:",
		"typescript": "catalog:react-native-tvos"
	},
	"expo": {
		"install": {
			"exclude": [
				"react-native"
			]
		}
	},
	"private": true
}
